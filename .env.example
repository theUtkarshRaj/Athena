# Copy to .env and fill in your key:  cp .env.example .env
#
# Athena uses cognee configured for Gemini (LLM + embeddings). All databases are
# file-based by default (SQLite / Kuzu / LanceDB) — no infra to run.

# --- Gemini (LLM + embeddings) ----------------------------------------------
LLM_API_KEY="your_gemini_api_key_here"
LLM_PROVIDER="gemini"
LLM_MODEL="gemini/gemini-2.5-flash"

EMBEDDING_PROVIDER="gemini"
EMBEDDING_MODEL="gemini/gemini-embedding-001"
EMBEDDING_API_KEY="your_gemini_api_key_here"
EMBEDDING_DIMENSIONS=3072

# --- single-user local mode (no auth, file-based defaults) -------------------
ENABLE_BACKEND_ACCESS_CONTROL=False
REQUIRE_AUTHENTICATION=False
TELEMETRY_DISABLED=1
LITELLM_LOG="ERROR"

# Which cognee dataset Athena stores memory in.
ATHENA_DATASET="athena"
