# secrets — never commit
.env

# cognee data stores — never commit (rebuilt from demo_data/ on first run)
.cognee/
.cognee_system/
.data_storage/

# python
__pycache__/
*.pyc
.venv/

# user-uploaded files (created at runtime by the app) — never commit
uploaded_data/

# logs & generated graph HTML
*.log
*.html

# dev scratch: probes, smoke tests, session notes (anything prefixed with _)
_*

# video demo props (generated PDFs) — not part of the app
demo_pdfs/
